generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  username      String         @unique
  email         String         @unique
  password      String?
  avatarUrl     String?
  bio           String?
  displayName   String?
  website       String?
  location      String?
  favoriteGenres String[]      @default([])
  createdAt     DateTime       @default(now())
  ratings       Rating[]
  reviews       Review[]
  lists         List[]
  following     Follow[]       @relation("follower")
  followers     Follow[]       @relation("following")
  debatePosts   DebatePost[]
  reviewComments ReviewComment[]
  notifications Notification[] @relation("notifRecipient")
  sentNotifs    Notification[] @relation("notifSender")
}

model Album {
  id          String  @id
  title       String
  artistName  String
  artistId    String
  releaseYear Int
  coverUrl    String?
  genres      String[]
  avgRating   Float?
  ratingCount Int      @default(0)
  ratings     Rating[]
  reviews     Review[]
  debates     DebatePost[]
}

model Rating {
  id        String   @id @default(cuid())
  userId    String
  albumId   String
  value     Float
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  album     Album    @relation(fields: [albumId], references: [id])
  @@unique([userId, albumId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  albumId   String
  body      String
  rating    Float?
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  album     Album    @relation(fields: [albumId], references: [id])
  comments  ReviewComment[]
  @@unique([userId, albumId])
}

model ReviewComment {
  id        String   @id @default(cuid())
  reviewId  String
  userId    String
  body      String
  parentId  String?
  createdAt DateTime @default(now())
  review    Review   @relation(fields: [reviewId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model List {
  id          String      @id @default(cuid())
  userId      String
  title       String
  description String?
  isPublic    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  user        User        @relation(fields: [userId], references: [id])
  entries     ListEntry[]
}

model ListEntry {
  id      String  @id @default(cuid())
  listId  String
  albumId String
  rank    Int
  note    String?
  list    List    @relation(fields: [listId], references: [id])
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("follower", fields: [followerId], references: [id])
  following   User     @relation("following", fields: [followingId], references: [id])
  @@id([followerId, followingId])
}

model DebatePost {
  id        String       @id @default(cuid())
  albumId   String
  userId    String
  body      String
  upvotes   Int          @default(0)
  downvotes Int          @default(0)
  parentId  String?
  createdAt DateTime     @default(now())
  album     Album        @relation(fields: [albumId], references: [id])
  user      User         @relation(fields: [userId], references: [id])
  replies   DebatePost[] @relation("replies")
  parent    DebatePost?  @relation("replies", fields: [parentId], references: [id])
}

model Notification {
  id          String   @id @default(cuid())
  recipientId String
  senderId    String?
  type        String   // "like" | "follow" | "comment" | "review" | "mention"
  message     String
  link        String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  recipient   User     @relation("notifRecipient", fields: [recipientId], references: [id])
  sender      User?    @relation("notifSender", fields: [senderId], references: [id])
}
