# ----- Phase 1 (finder) -----
# By default the finder runs in DEMO mode (no network, no keys) so the UI works
# out of the box. Set this to "true" to pull live markets from Polymarket's
# public, keyless APIs (Gamma + CLOB). No account or key required for reads.
POLYMARKET_LIVE=false

# Fee charged on net winnings, as a fraction. Polymarket's base platform has
# historically been 0; the International variant has taken up to 0.02 (2%).
# The finder subtracts this from every opportunity so ranked edges are NET.
POLYMARKET_FEE=0

# ----- Phase 3 (live execution) — NOT used by the finder. Leave blank for now. -----
# When/if we build auto-execution, create a DEDICATED BURNER WALLET, fund it
# with ONLY your small bankroll, and put its key here. Never your main wallet.
# This file is git-ignored; never commit a real key.
# POLYMARKET_PRIVATE_KEY=
