# POLYFUNNEL credentials — copy to .env and fill in. NEVER commit .env.
# .env is gitignored; the pre-commit secret scan is a second line of defense.

# Polygon wallet private key for py-clob-client (L1 auth). Required only for
# order placement (Phase 7) and authenticated CLOB endpoints. NOT needed for
# public market data (Phases 0-6 paper trading reads public endpoints).
POLYMARKET_PRIVATE_KEY=

# CLOB API credentials (L2 auth) — derived via py-clob-client create_or_derive_api_creds()
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Polymarket proxy/funder address (if using email/magic-link account)
POLYMARKET_FUNDER_ADDRESS=

# Optional: exchange API keys for ccxt (public candles need none)
