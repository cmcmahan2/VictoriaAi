# Required — Claude (metadata generation)
ANTHROPIC_API_KEY=sk-ant-...

# YouTube Data API v3 — OAuth2 (Google Cloud Console → Credentials)
# Scope needed: https://www.googleapis.com/auth/youtube.upload
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3002/api/auth/youtube
# Filled in after the OAuth consent flow; used for unattended uploads.
YOUTUBE_REFRESH_TOKEN=

# Optional — transcription for richer context (Whisper). If unset, the
# generator falls back to the source platform's original caption only.
OPENAI_API_KEY=

# Storage — libSQL/Turso. Leave blank to use a local file DB at DB_PATH.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
DB_PATH=./data/repurpose.db

# Where downloaded source clips are written before upload.
MEDIA_DIR=./tmp-media
