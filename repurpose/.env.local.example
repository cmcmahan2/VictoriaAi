# Required — Claude (metadata generation)
ANTHROPIC_API_KEY=sk-ant-...

# YouTube Data API v3 — OAuth2 (Google Cloud Console → Credentials)
# Scope needed: https://www.googleapis.com/auth/youtube.upload
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3002/api/auth/youtube
# Filled in after the OAuth consent flow; used for unattended uploads.
YOUTUBE_REFRESH_TOKEN=

# Voice (AI narration). ElevenLabs sounds the most human — recommended.
# If only OPENAI_API_KEY is set, OpenAI TTS is used as a fallback.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB   # default "Adam"; swap for your preferred voice
# TTS_PROVIDER=elevenlabs                  # force a provider; auto-detected otherwise
# OPENAI_TTS_VOICE=onyx                     # used when falling back to OpenAI TTS

# OpenAI — used for TTS fallback and (optional) Whisper transcription.
OPENAI_API_KEY=

# Optional — point at a specific ffmpeg binary. Leave blank to use the
# bundled @ffmpeg-installer/ffmpeg (no manual install needed).
# FFMPEG_PATH=

# Storage — libSQL/Turso. Leave blank to use a local file DB at DB_PATH.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
DB_PATH=./data/repurpose.db

# Where downloaded source clips are written before upload.
MEDIA_DIR=./tmp-media
