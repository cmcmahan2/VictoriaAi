# -----------------------------------------
# BCBUISWEBBUILDERTOOL - Environment Variables
# Copy this file to .env and fill in values
# -----------------------------------------

# --- Admin server -------------------------
# Password for the dashboard at http://localhost:5000
ADMIN_PASSWORD=changeme

# Port for the admin web server
PORT=5000

# --- Discovery ----------------------------
# Demo mode: realistic fake BC data, no API keys needed
# Set to false once you have a YELP_API_KEY or GOOGLE_MAPS_API_KEY
DEMO_MODE=false

# Tier 1 - Google Maps Places API (best quality)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Tier 2 - Yelp Fusion API (free, 500 calls/day)
# Get from: https://www.yelp.com/developers/v3/manage_app
YELP_API_KEY=your_yelp_api_key_here

# Tier 3 - Foursquare Places API (free, 1000 calls/day - Gmail OK)
# Get from: https://foursquare.com/developer  -> Create App -> API Key
FOURSQUARE_API_KEY=your_foursquare_api_key_here

# --- Core ---------------------------------
# Anthropic API key for AI content generation
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Deployment ---------------------------
# Netlify personal access token for auto-deploy
# Get from: https://app.netlify.com/user/applications
NETLIFY_AUTH_TOKEN=your_netlify_auth_token_here

# Netlify team slug (leave blank for personal accounts)
NETLIFY_TEAM_SLUG=

# --- Defaults -----------------------------
DEFAULT_RADIUS_KM=15
MAX_LEADS=50

# --- Discovery cache ----------------------
# Caches Google/OpenStreetMap lookups + website-health checks in a local
# SQLite file so repeat / province-wide sweeps don't re-hit external APIs.
# Lives in output/ (gitignored). Safe defaults - usually no need to change.
CACHE_DB=./output/cache.db
CACHE_TTL_DAYS=7
# Set to true to bypass the cache entirely (always fetch fresh)
CACHE_DISABLED=false

# --- Logging ------------------------------
# Structured logs stream to the dashboard AND a rotating file in output/logs/
# (gitignored). View the tail in the Jobs tab via "View server logs".
LOG_DIR=./output/logs
LOG_LEVEL=INFO
# Rotate after this many bytes, keeping LOG_BACKUPS old files.
LOG_MAX_BYTES=5000000
LOG_BACKUPS=5
