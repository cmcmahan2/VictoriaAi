# ── Wholesale Engine environment ──────────────────────────────────────────────
# Copy this file to `.env.local` for local dev, or set these in your Vercel
# project's Environment Variables. The app runs without any of them (demo mode),
# but each key unlocks real capability:

# Claude — REQUIRED for real deal scoring. Without it, scores use a mock formula.
# Get one: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# RentCast — real for-sale listings. Free tier ~50 requests/month.
# Get one: https://app.rentcast.io/app/api
RENTCAST_API_KEY=

# Database (optional) — persists saved searches, buyers, and alerts across
# deploys. Without it the app works but nothing is saved. Free tier is plenty.
# Sign up: https://turso.tech  →  create a DB  →  copy URL + token
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Optional extra data providers (leave blank if you don't have them)
ZILLOW_API_KEY=
ATTOM_API_KEY=

# Optional — outbound alert emails. Get one: https://resend.com/api-keys
RESEND_API_KEY=
